# Copie ce fichier en .env (gitignoré) pour un run manuel hors CI.
# En CI, ces valeurs vivent dans les secrets GitHub Actions, pas ici.

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- SMTP : envoi depuis TON Gmail ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ton.adresse@gmail.com        # le compte Gmail qui envoie
SMTP_PASS=                              # mot de passe d'application Google (16 car., 2FA requise)
MAIL_FROM=ton.adresse@gmail.com         # Gmail force le From sur le compte authentifié
MAIL_TO=bertrand.coizy@edenred.com      # destinataire (simple adresse d'arrivée)
